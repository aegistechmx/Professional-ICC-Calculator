{
  "name": "professional-icc-calculator",
  "version": "1.0.0",
  "description": "Professional ICC Calculator - Electrical system analysis tool",
  "scripts": {
    "start": "concurrently \"npm run backend\" \"npm run frontend\"",
    "backend": "cd backend && npm run dev",
    "frontend": "cd frontend && npm run dev",
    "build": "cd frontend && npm run build",
    "preview": "cd frontend && npm run preview",
    "analyze": "cd frontend && npm run analyze",
    "test": "cd frontend && npm run test:run && cd ../backend && npm test",
    "test:and:fix": "node scripts/run-tests-and-fix.js",
    "fix:ports": "node scripts/run-tests-and-fix.js --kill-ports-only",
    "lint:check": "cd frontend && npm run lint && cd ../backend && npm run lint",
    "test:coverage": "cd frontend && npm run test:run -- --coverage && cd ../backend && npm run test:coverage",
    "test:e2e": "cd frontend && npm run test:e2e",
    "test:integration": "cd backend && npm run test:integration",
    "test:security": "cd backend && npm run test:security",
    "test:penetration": "cd backend && npm run test:penetration",
    "test:input-validation": "cd backend && npm run test:input-validation",
    "test:electrical-standards": "cd backend && npm run test:electrical-standards",
    "test:short-circuit-accuracy": "cd backend && npm run test:short-circuit-accuracy",
    "test:mathematical-precision": "cd backend && npm run test:mathematical-precision",
    "test:complex-numbers": "cd backend && npm run test:complex-numbers",
    "test:matrix-calculations": "cd backend && npm run test:matrix-calculations",
    "test:zero-impedance": "cd backend && npm run test:zero-impedance",
    "test:infinite-impedance": "cd backend && npm run test:infinite-impedance",
    "test:boundary-conditions": "cd backend && npm run test:boundary-conditions",
    "test:large-systems": "cd backend && npm run test:large-systems",
    "test:convergence-criteria": "cd backend && npm run test:convergence-criteria",
    "test:electrical-integration": "npm run test:electrical-integration",
    "test:data-flow-accuracy": "npm run test:data-flow-accuracy",
    "test:report-accuracy": "npm run test:report-accuracy",
    "security:sast": "npm run security:sast",
    "security:codeql": "npm run security:codeql",
    "security:export-report": "node scripts/generate-security-report.js",
    "measure:performance": "node scripts/measure-performance.js",
    "audit:core-vitals": "node scripts/audit-core-vitals.js",
    "analyze:cache-performance": "npm run analyze:cache-performance",
    "analyze:bottlenecks": "cd backend && npm run analyze:bottlenecks",
    "measure:api-performance": "cd backend && npm run measure:api-performance",
    "analyze:memory": "npm run analyze:memory",
    "profile:memory": "npm run profile:memory",
    "optimize:memory": "npm run optimize:memory",
    "db:slow-queries": "cd backend && npm run db:slow-queries",
    "db:index-analysis": "cd backend && npm run db:index-analysis",
    "db:profile": "cd backend && npm run db:profile",
    "db:migrate": "cd backend && npm run db:migrate",
    "validate:ieee-1584": "cd backend && npm run validate:ieee-1584",
    "validate:iec-60909": "cd backend && npm run validate:iec-60909",
    "validate:nec-compliance": "cd backend && npm run validate:nec-compliance"
  },
  "dependencies": {
    "@xyflow/react": "^12.10.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "concurrently": "^8.2.2",
    "playwright": "^1.59.1"
  }
}
