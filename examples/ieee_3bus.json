{
  "name": "IEEE 3-Bus System",
  "description": "Standard IEEE 3-bus test system for power flow validation",
  "reference": "IEEE Standard Test Systems",
  "baseMVA": 100,
  "baseKV": 13.8,
  "expectedResults": {
    "bus2_voltage": 1.045,
    "bus3_voltage": 1.030,
    "line1_flow_MW": 50.5,
    "line2_flow_MW": 30.2
  },
  "buses": [
    {
      "id": "bus1",
      "type": "Slack",
      "baseKV": 13.8,
      "voltage": { "magnitude": 1.05, "angle": 0 },
      "generation": { "P": 100, "Q": 50 }
    },
    {
      "id": "bus2",
      "type": "PV",
      "baseKV": 13.8,
      "voltage": { "magnitude": 1.045, "angle": 0 },
      "generation": { "P": 50, "Q": 25 }
    },
    {
      "id": "bus3",
      "type": "PQ",
      "baseKV": 13.8,
      "voltage": { "magnitude": 1.0, "angle": 0 },
      "load": { "P": 80, "Q": 40 }
    }
  ],
  "lines": [
    {
      "id": "line1",
      "fromBus": "bus1",
      "toBus": "bus2",
      "r": 0.01,
      "x": 0.1,
      "b": 0.0,
      "thermalLimit": 100
    },
    {
      "id": "line2",
      "fromBus": "bus2",
      "toBus": "bus3",
      "r": 0.015,
      "x": 0.12,
      "b": 0.0,
      "thermalLimit": 80
    },
    {
      "id": "line3",
      "fromBus": "bus1",
      "toBus": "bus3",
      "r": 0.02,
      "x": 0.15,
      "b": 0.0,
      "thermalLimit": 120
    }
  ]
}
