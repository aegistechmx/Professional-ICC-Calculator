{
  "name": "icc-backend",
  "version": "1.0.0",
  "main": "src/server.js",
  "scripts": {
    "dev": "set PORT=3001 && nodemon src/server.js",
    "start": "set PORT=3001 && node src/server.js",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix",
    "format": "prettier --write \"src/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.js\"",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.76.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^8.4.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "mathjs": "^12.4.0",
    "pdfkit": "^0.14.0",
    "serverless-http": "^4.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-standard": "^5.0.0",
    "jest": "^30.3.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.8.3",
    "prisma": "^5.10.0",
    "supertest": "^7.2.2",
    "typescript": "^6.0.3"
  },
  "_moduleAliases": {
    "@": "src",
    "@core": "src/core",
    "@app": "src/application",
    "@infrastructure": "src/infrastructure",
    "@shared": "src/shared"
  }
